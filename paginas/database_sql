- cria também um Id dentro do banco, disponível como chave primária  para melhor organização e identificação do usuário para os adms.
CREATE TABLE usuario (
    IdUsuario INT PRIMARY KEY AUTO_INCREMENT,
    DataCadastro TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    DataAtualizacao TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
    NomeUsuario VARCHAR(60) NOT NULL UNIQUE,
    EmailUsuario VARCHAR(60) NOT NULL UNIQUE,
    SenhaHash char(60) NOT NULL
    );

